{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-of-abyss/schemas/ecosystem-registry.schema.json",
  "title": "AoA ecosystem registry v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "ecosystem", "repos"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "ecosystem": {
      "type": "string",
      "const": "AoA"
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "visibility", "maturity", "relation", "kind"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3
          },
          "role": {
            "type": "string",
            "minLength": 3
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "private"
            ]
          },
          "maturity": {
            "type": "string",
            "enum": ["concept", "bootstrap", "active", "stable", "deprecated"]
          },
          "relation": {
            "type": "string",
            "enum": [
              "center",
              "source-layer",
              "derived-layer",
              "routing-layer",
              "substrate",
              "counterpart",
              "supporting-consumer",
              "public-projection",
              "private-project"
            ]
          },
          "kind": {
            "type": "string",
            "enum": ["meta", "source", "derived", "related"]
          }
        }
      }
    }
  }
}
