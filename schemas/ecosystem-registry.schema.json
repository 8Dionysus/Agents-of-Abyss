{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-of-abyss/schemas/ecosystem-registry.schema.json",
  "title": "AoA ecosystem registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "ecosystem", "repos"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "ecosystem": {
      "type": "string",
      "const": "AoA"
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "status", "shared_maturity", "kind"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3
          },
          "role": {
            "type": "string",
            "minLength": 3
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "bootstrap",
              "planned",
              "active-private",
              "active-conceptual",
              "related",
              "experimental",
              "deprecated"
            ]
          },
          "shared_maturity": {
            "type": "string",
            "enum": ["seed", "proven", "promoted", "canonical", "deprecated"]
          },
          "kind": {
            "type": "string",
            "enum": ["meta", "source", "derived", "related"]
          }
        }
      }
    }
  }
}
