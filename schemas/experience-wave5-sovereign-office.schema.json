{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/schemas/experience-wave5-sovereign-office.schema.json",
  "title": "experience_wave5_sovereign_office_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "wave",
    "status",
    "source_seeds",
    "installation_flow",
    "office_train_flow",
    "authority",
    "office_contract",
    "owner_split"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "experience_wave5_sovereign_office_v1"
    },
    "wave": {
      "type": "string",
      "const": "experience_wave5"
    },
    "status": {
      "type": "string",
      "const": "sovereign_release_live_office_expansion_contract_gated"
    },
    "source_seeds": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "installation_flow": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/flow_step"
      }
    },
    "office_train_flow": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/flow_step"
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_effect",
        "codex_may",
        "codex_must_not",
        "assistant_must_not",
        "human_authority_required"
      ],
      "properties": {
        "runtime_effect": {
          "type": "string",
          "const": "contract_only"
        },
        "codex_may": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "codex_must_not": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "assistant_must_not": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "human_authority_required": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "office_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first_office",
        "required_primary_offices",
        "non_primary_until_promoted",
        "office_kind",
        "evolution_mode",
        "self_modification_allowed",
        "direct_tos_runtime_write_allowed"
      ],
      "properties": {
        "first_office": {
          "type": "string",
          "const": "notary.assistant"
        },
        "required_primary_offices": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "non_primary_until_promoted": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "office_kind": {
          "type": "string",
          "const": "assistant"
        },
        "evolution_mode": {
          "type": "string",
          "const": "exogenous_reactive"
        },
        "self_modification_allowed": {
          "type": "boolean",
          "const": false
        },
        "direct_tos_runtime_write_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "owner_split": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "items": {
        "$ref": "#/$defs/owner_split_entry"
      }
    }
  },
  "$defs": {
    "flow_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "owner_repo",
        "authority_note"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "owner_repo": {
          "$ref": "#/$defs/repo"
        },
        "authority_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "owner_split_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "owns",
        "must_not"
      ],
      "properties": {
        "repo": {
          "$ref": "#/$defs/repo"
        },
        "owns": {
          "type": "string",
          "minLength": 1
        },
        "must_not": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "repo": {
      "type": "string",
      "enum": [
        "Agents-of-Abyss",
        "Tree-of-Sophia",
        "abyss-stack",
        "aoa-agents",
        "aoa-evals",
        "aoa-kag",
        "aoa-memo",
        "aoa-playbooks",
        "aoa-routing",
        "aoa-sdk",
        "aoa-skills",
        "aoa-stats",
        "aoa-techniques"
      ]
    }
  }
}
