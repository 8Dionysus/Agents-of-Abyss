{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/Agents-of-Abyss/main/schemas/center-entry-map.schema.json",
  "title": "AoA center entry map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "authority_ref",
    "public_root_ref",
    "registry_ref",
    "supporting_inventory_ref",
    "validation_refs",
    "routes"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_center_entry_map_v1"
    },
    "schema_ref": {
      "const": "schemas/center-entry-map.schema.json"
    },
    "owner_repo": {
      "const": "Agents-of-Abyss"
    },
    "surface_kind": {
      "const": "center_entry_map"
    },
    "authority_ref": {
      "$ref": "#/$defs/repoRelativeSurface"
    },
    "public_root_ref": {
      "$ref": "#/$defs/repoRelativeSurface"
    },
    "registry_ref": {
      "$ref": "#/$defs/repoRelativeSurface"
    },
    "supporting_inventory_ref": {
      "$ref": "#/$defs/repoRelativeSurface"
    },
    "validation_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/repoRelativeSurface"
      }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/route"
      }
    }
  },
  "$defs": {
    "repoRelativeSurface": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z0-9_-]+:)(?![A-Za-z]:[\\\\/])(?![\\\\/])(?!\\.\\.?[\\\\/])[A-Za-z0-9._/#-]+$"
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "need",
        "surface_ref",
        "verification_refs"
      ],
      "properties": {
        "route_id": {
          "type": "string",
          "minLength": 1
        },
        "need": {
          "type": "string",
          "minLength": 1
        },
        "surface_ref": {
          "$ref": "#/$defs/repoRelativeSurface"
        },
        "verification_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/repoRelativeSurface"
          }
        }
      }
    }
  }
}
