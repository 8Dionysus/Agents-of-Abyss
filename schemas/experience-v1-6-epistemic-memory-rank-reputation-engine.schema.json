    "consequence_flow": {
      "const": [
        {
          "order": 1,
          "kind": "source_seed_received",
          "owner": "Agents-of-Abyss",
          "authority_note": "Dionysus archive is transport evidence; center may name v1.6 standing and rights law only",
          "stop_lines": [
            "no raw archive replay",
            "no generated clean-flow promotion"
          ]
        },
        {
          "order": 2,
          "kind": "wave5_epistemic_predecessor_checked",
          "owner": "Agents-of-Abyss",
          "authority_note": "v1.5 remains predecessor law; v1.6 may only add consequence grammar after the epistemic layer",
          "stop_lines": [
            "no wave16 collapse",
            "no predecessor erasure"
          ]
        },
        {
          "order": 3,
          "kind": "consequence_charter_requested",
          "owner": "Agents-of-Abyss",
          "authority_note": "charter is required before any later owner-local standing or rights landing can be considered",
          "stop_lines": [
            "no center-created live standing",
            "no rights by declaration"
          ]
        },
        {
          "order": 4,
          "kind": "reputation_event_review_requested",
          "owner": "aoa-evals",
          "authority_note": "reputation review may produce a candidate packet but cannot issue final standing or rights",
          "stop_lines": [
            "no reputation without evidence",
            "no direct rights grant"
          ]
        },
        {
          "order": 5,
          "kind": "memo_intake_candidate_requested",
          "owner": "aoa-memo",
          "authority_note": "memo may receive bounded consequence candidates but cannot convert them into durable truth here",
          "stop_lines": [
            "no durable memory write",
            "no memo as truth"
          ]
        },
        {
          "order": 6,
          "kind": "retention_check_candidate_requested",
          "owner": "aoa-memo",
          "authority_note": "retention windows remain candidate-only and may not become scheduler execution or automatic decay",
          "stop_lines": [
            "no scheduler loop",
            "no automatic decay execution"
          ]
        },
        {
          "order": 7,
          "kind": "repeated_retention_result_candidate_checked",
          "owner": "aoa-evals",
          "authority_note": "retention legitimacy may be checked as bounded evidence without mutating standing on its own",
          "stop_lines": [
            "no one-event retention win",
            "no retention without recurrence"
          ]
        },
        {
          "order": 8,
          "kind": "standing_and_jurisdiction_candidate_requested",
          "owner": "aoa-agents",
          "authority_note": "standing and jurisdiction remain owner-local candidates and may not be assigned by assistants or Codex",
          "stop_lines": [
            "no assistant agonic rank",
            "no codex standing authority"
          ]
        },
        {
          "order": 9,
          "kind": "summon_and_closure_rights_gate_checked",
          "owner": "aoa-agents",
          "authority_note": "summon and closure stay reviewed jurisdictions behind contradiction law and visible cost",
          "stop_lines": [
            "no closure over open contradiction",
            "no summon without visible cost"
          ]
        },
        {
          "order": 10,
          "kind": "derived_observability_candidate_requested",
          "owner": "aoa-stats",
          "authority_note": "derived dashboards may summarize bounded packets but cannot become proof, score, or verdict authority",
          "stop_lines": [
            "no stats as proof",
            "no dashboard as verdict"
          ]
        },
        {
          "order": 11,
          "kind": "owner_landing_or_recharter_request_declared",
          "owner": "Agents-of-Abyss",
          "authority_note": "future consequence work returns to owner-local landing or human recharter as requests",
          "stop_lines": [
            "no runtime ledger activation",
            "no direct Tree-of-Sophia or KAG canon"
          ]
        }
      ]
