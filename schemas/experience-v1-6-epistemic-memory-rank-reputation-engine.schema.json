        {
          "request": "retention_window_review",
          "owner": "aoa-memo",
          "input_boundary": "scar delta recurrence record reentry evidence and owner review posture",
          "output_candidate": "retention_result_candidate",
          "must_include": [
            "reentry_window",
            "recurrence_trace",
            "owner_review_needed",
