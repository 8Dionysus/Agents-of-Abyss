{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-of-abyss/schemas/federation-supporting-inventory.schema.json",
  "title": "AoA federation supporting inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "inventory", "center_registry_ref", "repos"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "inventory": {
      "type": "string",
      "const": "AoA-supporting-surfaces"
    },
    "center_registry_ref": {
      "type": "string",
      "const": "generated/ecosystem_registry.min.json"
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "role",
          "status",
          "shared_maturity",
          "kind",
          "boundary"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3
          },
          "role": {
            "type": "string",
            "minLength": 3
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "bootstrap",
              "planned",
              "active-private",
              "active-conceptual",
              "related",
              "experimental",
              "deprecated"
            ]
          },
          "shared_maturity": {
            "type": "string",
            "enum": ["seed", "proven", "promoted", "canonical", "deprecated"]
          },
          "kind": {
            "type": "string",
            "const": "supporting-consumer"
          },
          "boundary": {
            "type": "string",
            "minLength": 12
          }
        }
      }
    }
  }
}
