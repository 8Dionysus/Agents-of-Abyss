{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/schemas/experience_live_assistant_office_v1.json",
  "title": "Experience Live Assistant Office V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "created_at",
    "evidence_refs",
    "id",
    "kind",
    "notes",
    "office",
    "owner_repo",
    "service_contract_ref",
    "status",
    "version"
  ],
  "properties": {
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "assistant"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "office": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "Agents-of-Abyss"
    },
    "service_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.0.0"
    }
  }
}
