{
  "$id": "https://8dionysus.local/schemas/agon-trial-playbook-request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "live_protocol": {
      "const": false
    },
    "requested_trial_playbooks": {
      "minItems": 1,
      "type": "array"
    },
    "runtime_effect": {
      "const": "none"
    },
    "schema_version": {
      "const": "agon-trial-playbook-request-v1"
    },
    "target_repo": {
      "const": "aoa-playbooks"
    },
    "wave": {
      "const": "VI"
    }
  },
  "required": [
    "schema_version",
    "wave",
    "target_repo",
    "requested_trial_playbooks",
    "stop_lines",
    "live_protocol",
    "runtime_effect"
  ],
  "title": "Agon Trial Playbook Request",
  "type": "object"
}
