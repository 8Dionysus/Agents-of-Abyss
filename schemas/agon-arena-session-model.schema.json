{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "charter": {
      "type": "object"
    },
    "lifecycle": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "live_protocol": {
      "const": false,
      "type": "boolean"
    },
    "owner_handoffs": {
      "type": "object"
    },
    "pressure_profiles": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "profile": {
      "type": "string"
    },
    "runtime_effect": {
      "const": "none",
      "type": "string"
    },
    "seats": {
      "type": "object"
    },
    "session_model_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "terminal_outcomes": {
      "items": {
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "session_model_id",
    "status",
    "profile",
    "live_protocol",
    "runtime_effect",
    "charter",
    "seats",
    "lifecycle",
    "pressure_profiles",
    "terminal_outcomes",
    "owner_handoffs"
  ],
  "title": "Agon Arena Session Model",
  "type": "object"
}
