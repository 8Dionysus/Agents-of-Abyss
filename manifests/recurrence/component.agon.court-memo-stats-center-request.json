{
  "beacon_rules": [
    {
      "beacon_ref": "agon.wave7.center_prebinding_pressure",
      "kind": "review_signal",
      "match_categories": [
        "change_pressure",
        "review_signal"
      ],
      "match_signals": [
        "wave7_request_changed",
        "prebinding_owner_gap_detected"
      ],
      "notes": "Center request drift can ask for review; it must not activate the arena.",
      "observation_inputs": [
        "agon-wave7-center-request",
        "agon-wave7-center-docs"
      ],
      "recommended_actions": [
        "review owner prebinding status",
        "do not create arena protocol"
      ],
      "status_ladder": [
        "hint",
        "watch",
        "candidate",
        "review_ready"
      ],
      "suppress_when": [
        "live_verdict_authority_claim_present",
        "durable_scar_write_claim_present"
      ],
      "target_repo": "Agents-of-Abyss",
      "thresholds": {
        "candidate_observations": 2,
        "min_unique_evidence_refs": 2,
        "min_unique_sources": 2,
        "review_ready_observations": 3,
        "watch_observations": 1
      }
    }
  ],
  "candidate_targets": [
    "mechanics/agon/generated/agon_court_memo_stats_prebinding_request.min.json"
  ],
  "component_ref": "component:agon:court-memo-stats-center-request",
  "contract_surfaces": [
    "mechanics/agon/docs/AGON_COURT_MEMO_STATS_PREBINDING_HANDOFF.md",
    "mechanics/agon/docs/AGON_COURT_MEMO_STATS_PREBINDING_STOP_LINES.md"
  ],
  "description": "Center-owned Wave VII request for court, memory, and stats prebinding.",
  "freshness": {
    "open_window_days": 7,
    "repeat_trigger_threshold": 2,
    "stale_after_days": 14
  },
  "generated_surfaces": [
    "mechanics/agon/generated/agon_court_memo_stats_prebinding_request.min.json"
  ],
  "observation_inputs": [
    {
      "input_ref": "agon-wave7-center-request",
      "kind": "other",
      "notes": "Wave VII center request surface.",
      "path_globs": [
        "mechanics/agon/generated/agon_court_memo_stats_prebinding_request.min.json"
      ]
    },
    {
      "input_ref": "agon-wave7-center-docs",
      "kind": "review_note",
      "notes": "Wave VII handoff and stop-line docs.",
      "path_globs": [
        "docs/AGON_COURT_MEMO_STATS_*.md",
        "docs/AGON_WAVE7_*.md"
      ]
    }
  ],
  "owner_repo": "Agents-of-Abyss",
  "proof_surfaces": [
    "python mechanics/agon/scripts/validate_agon_court_memo_stats_prebinding_request.py"
  ],
  "rollback_anchors": [
    "mechanics/agon/docs/AGON_COURT_MEMO_STATS_PREBINDING_STOP_LINES.md"
  ],
  "schema_version": "aoa_recurrence_component_v2",
  "signal_edges": [
    {
      "kind": "proved_by_eval",
      "notes": "Court prebinding receives proof pressure only.",
      "target": "component:agon:court-prebinding-surfaces",
      "target_repo": "aoa-evals"
    },
    {
      "kind": "remembered_by_memo",
      "notes": "Memo prebinding receives candidate memory pressure only.",
      "target": "component:agon:memory-prebinding-surfaces",
      "target_repo": "aoa-memo"
    },
    {
      "kind": "observed_by_stats",
      "notes": "Stats prebinding receives derived observability pressure only.",
      "target": "component:agon:stats-prebinding-surfaces",
      "target_repo": "aoa-stats"
    }
  ],
  "source_inputs": [
    "mechanics/agon/config/agon_court_memo_stats_prebinding_request.seed.json"
  ],
  "tags": [
    "agon",
    "wave7",
    "prebinding",
    "court",
    "memo",
    "stats",
    "recurrence"
  ]
}
