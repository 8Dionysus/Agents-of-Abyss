{
  "component_ref": "component:agon:arena-session-model-surfaces",
  "hooks": [
    {
      "does_not": [
        "auto_rebuild",
        "open_session",
        "issue_verdict"
      ],
      "emits": "review_queue_candidate",
      "hook_ref": "agon.wave8.hook.session_model_registry_drift",
      "observes": "mechanics/agon/parts/packet-arena/generated/agon_arena_session_model_registry.min.json"
    },
    {
      "does_not": [
        "mutate_owner_repo",
        "write_memory",
        "rank_agents"
      ],
      "emits": "owner_review_summary",
      "hook_ref": "agon.wave8.hook.session_model_stop_line_drift",
      "observes": "mechanics/agon/parts/packet-arena/config/agon_arena_session_models.seed.json"
    }
  ],
  "live_protocol": false,
  "must_not": [
    "no_live_session_instance_creation",
    "no_runtime_state_transition",
    "no_sealed_commit_packet_definition",
    "no_live_move_execution",
    "no_verdict_authority",
    "no_durable_scar_write",
    "no_retention_execution",
    "no_rank_mutation",
    "no_tree_of_sophia_promotion",
    "no_hidden_scheduler_action",
    "no_assistant_contestant_drift",
    "no_center_takeover_of_owner_truth"
  ],
  "owner_repo": "Agents-of-Abyss",
  "runtime_effect": "none",
  "schema_version": "recurrence_hook_binding_set_v1",
  "status": "seeded_hook_binding_candidates_for_agon_wave8"
}
