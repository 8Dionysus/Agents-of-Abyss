{
  "schema_version": 2,
  "purpose": "Keep docs/ current and route historical, evidential, and support material into named homes without creating empty mechanic doors.",
  "current_root_allowlist": [
    "AGENTS.md",
    "README.md",
    "FEDERATION_RULES.md",
    "LAYERS.md",
    "REPO_ROLES.md",
    "ROOT_SURFACE_LAW.md",
    "START_HERE_ROUTE_CONTRACT.md",
    "MECHANICS.md"
  ],
  "districts": {
    "guardrails": {
      "path": "docs/guardrails",
      "readme": "docs/guardrails/README.md",
      "role": "Validator law, hygiene protocol, local AGENTS mesh law, generated index source maps, and docs cleanup classifier.",
      "authority": "guardrail_source",
      "patterns": [
        "GUARDRAIL",
        "HYGIENE",
        "AGENTS_MESH",
        "THEMATIC_DISTRICT",
        "CURRENT_SURFACE",
        "LINK_AND_SHAPE"
      ],
      "must_not_claim": [
        "Guardrails verify route shape; they do not author center doctrine or mechanic truth."
      ]
    },
    "decisions": {
      "path": "docs/decisions",
      "readme": "docs/decisions/README.md",
      "role": "Decision records explaining why a route, owner split, or placement was chosen.",
      "authority": "decision_record",
      "patterns": [
        "DECISION",
        "ADR",
        "RFC",
        "RATIONALE"
      ],
      "must_not_claim": [
        "Decisions explain why; current surfaces define what."
      ]
    },
    "traces": {
      "path": "docs/traces",
      "readme": "docs/traces/README.md",
      "role": "Migration evidence, provenance logs, link rewrite traces, and move manifests.",
      "authority": "provenance_trace",
      "patterns": [
        "TRACE",
        "PROVENANCE",
        "MIGRATION",
        "BEFORE_AFTER",
        "MOVE_LOG",
        "LINK_REWRITE",
        "MANIFEST",
        "LANDING",
        "SEED",
        "RECEIPT"
      ],
      "must_not_claim": [
        "Traces explain movement, not meaning."
      ]
    }
  },
  "tie_break_order": [
    "guardrails",
    "decisions",
    "traces"
  ],
  "exact_migrations": [
    {
      "source": "docs/AGENTS_MESH_INDEX.md",
      "target": "docs/guardrails/AGENTS_MESH_INDEX.md",
      "district": "guardrails",
      "link_target": "docs/guardrails/AGENTS_MESH_INDEX.md",
      "reason": "AGENTS mesh index is validator guardrail law, not center doctrine"
    },
    {
      "source": "docs/AGENTS_MESH_PROTOCOL.md",
      "target": "docs/guardrails/AGENTS_MESH_PROTOCOL.md",
      "district": "guardrails",
      "link_target": "docs/guardrails/AGENTS_MESH_PROTOCOL.md",
      "reason": "AGENTS mesh protocol is validator guardrail law, not center doctrine"
    },
    {
      "source": "docs/CURRENT_SURFACE_INDEX.md",
      "target": "docs/guardrails/CURRENT_SURFACE_INDEX.md",
      "district": "guardrails",
      "link_target": "docs/guardrails/CURRENT_SURFACE_INDEX.md",
      "reason": "docs root current-surface inventory belongs with guardrail maps"
    },
    {
      "source": "docs/HYGIENE_GUARDRAIL_INDEX.md",
      "target": "docs/guardrails/HYGIENE_GUARDRAIL_INDEX.md",
      "district": "guardrails",
      "link_target": "docs/guardrails/HYGIENE_GUARDRAIL_INDEX.md",
      "reason": "hygiene index is validator guardrail law, not center doctrine"
    },
    {
      "source": "docs/LINK_AND_SHAPE_HYGIENE_PROTOCOL.md",
      "target": "docs/guardrails/LINK_AND_SHAPE_HYGIENE_PROTOCOL.md",
      "district": "guardrails",
      "link_target": "docs/guardrails/LINK_AND_SHAPE_HYGIENE_PROTOCOL.md",
      "reason": "link and shape hygiene protocol is validator guardrail law"
    },
    {
      "source": "docs/THEMATIC_DISTRICT_PROTOCOL.md",
      "target": "docs/guardrails/THEMATIC_DISTRICT_PROTOCOL.md",
      "district": "guardrails",
      "link_target": "docs/guardrails/THEMATIC_DISTRICT_PROTOCOL.md",
      "reason": "docs thematic cleanup protocol is guardrail law"
    },
    {
      "source": "docs/thematic_districts.json",
      "target": "docs/guardrails/thematic_districts.json",
      "district": "guardrails",
      "link_target": "docs/guardrails/thematic_districts.json",
      "reason": "docs cleanup classifier is guardrail config"
    }
  ],
