{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/schemas/office_train_rollback_plan_v1.json",
  "title": "Office Train Rollback Plan V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "created_at",
    "evidence_refs",
    "id",
    "kind",
    "notes",
    "owner_repo",
    "quarantine_available",
    "rollback_available",
    "scope",
    "status",
    "train_id",
    "version"
  ],
  "properties": {
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "office_train_rollback_plan_v1"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "Agents-of-Abyss"
    },
    "quarantine_available": {
      "type": "boolean",
      "const": true
    },
    "rollback_available": {
      "type": "boolean",
      "const": true
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "train_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.1.0"
    }
  }
}
