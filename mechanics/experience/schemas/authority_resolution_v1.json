        "seal_final_decision"
      ]
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "denied"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "resolution_id": {
      "type": "string",
      "minLength": 1
    },
    "resolved_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
