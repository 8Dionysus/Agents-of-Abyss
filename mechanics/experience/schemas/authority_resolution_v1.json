{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/schemas/authority_resolution_v1.json",
  "title": "authority_resolution_v1",
  "description": "Seed schema for authority_resolution_v1 in Experience Constitution Runtime v0.9.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "actor_id",
    "decision",
    "reason",
    "resolution_id",
    "resolved_at"
  ],
  "properties": {
    "action": {
      "type": "string",
      "minLength": 1,
