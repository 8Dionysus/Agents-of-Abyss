{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/schemas/multi_office_release_train_v1.json",
  "title": "Multi Office Release Train V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "created_at",
    "evidence_refs",
    "gates",
    "id",
    "kind",
    "notes",
    "offices",
    "owner_repo",
    "rollback_plan_ref",
    "status",
    "train_id",
    "version"
  ],
  "properties": {
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "multi_office_release_train_v1"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "offices": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "Agents-of-Abyss"
    },
    "rollback_plan_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "train_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.1.0"
    }
  }
}
