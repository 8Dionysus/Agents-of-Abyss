{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/schemas/experience_operator_console_state_v1.json",
  "title": "Experience Operator Console State V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "allowed_actions",
    "created_at",
    "evidence_refs",
    "id",
    "kind",
    "notes",
    "owner_repo",
    "queues",
    "status",
    "version"
  ],
  "properties": {
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "experience_operator_console_state_v1"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "Agents-of-Abyss"
    },
    "queues": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hold",
        "release",
        "review"
      ],
      "properties": {
        "hold": {
          "type": "integer",
          "minimum": 0
        },
        "release": {
          "type": "integer",
          "minimum": 0
        },
        "review": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.0.0"
    }
  }
}
