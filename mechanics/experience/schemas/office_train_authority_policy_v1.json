{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/schemas/office_train_authority_policy_v1.json",
  "title": "Office Train Authority Policy V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "created_at",
    "denied_actions",
    "evidence_refs",
    "id",
    "kind",
    "notes",
    "operator_actions",
    "owner_repo",
    "status",
    "version"
  ],
  "properties": {
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "denied_actions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assistant",
        "codex"
      ],
      "properties": {
        "assistant": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "codex": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "office_train_authority_policy_v1"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "operator_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "Agents-of-Abyss"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.1.0"
    }
  }
}
