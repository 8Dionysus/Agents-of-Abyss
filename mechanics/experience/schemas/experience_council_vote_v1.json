{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/schemas/experience_council_vote_v1.json",
  "title": "Experience Council Vote V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority",
    "case_ref",
    "created_at",
    "decision_refs",
    "evidence_refs",
    "id",
    "kind",
    "notes",
    "reason",
    "recused",
    "schema_version",
    "status",
    "vote",
    "voter"
  ],
  "properties": {
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor",
        "mode"
      ],
      "properties": {
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "reviewed"
          ]
        }
      }
    },
    "case_ref": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "decision_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "experience.council.vote"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "recused": {
      "type": "boolean",
      "const": false
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "const": "v1"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "proposed"
      ]
    },
    "vote": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "approve_with_conditions"
      ]
    },
    "voter": {
      "type": "string",
      "minLength": 1
    }
  }
}
