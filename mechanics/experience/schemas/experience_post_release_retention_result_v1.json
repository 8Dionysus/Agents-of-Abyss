    },
    "check_cycle": {
      "type": "integer"
    },
    "outcome": {
      "type": "string"
    },
    "recurrence_reduced": {
      "type": "boolean"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
