{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/schemas/experience_dispute_record_v1.json",
  "title": "Experience Dispute Record V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority",
    "created_at",
    "decision_refs",
    "disputants",
    "evidence_refs",
    "id",
    "issue",
    "kind",
    "notes",
    "resolution_state",
    "schema_version",
    "status"
  ],
  "properties": {
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor",
        "mode"
      ],
      "properties": {
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "reviewed"
          ]
        }
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "decision_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "disputants": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "issue": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "experience.dispute_record"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "resolution_state": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "const": "v1"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "proposed"
      ]
    }
  }
}
