{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/parts/governance-polis/schemas/experience-polis-constitution.schema.json",
  "title": "experience_polis_constitution_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_ref",
    "status",
    "source_receipt_refs",
    "polis_flow",
    "runtime_flow",
    "authority",
    "owner_split"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "experience_polis_constitution_v1"
    },
    "contract_ref": {
      "type": "string",
      "const": "experience_polis_constitution"
    },
    "status": {
      "type": "string",
      "const": "polis_governance_constitution_runtime_contract_gated"
    },
    "source_receipt_refs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "polis_flow": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/flow_step"
      }
    },
    "runtime_flow": {
      "type": "array",
      "minItems": 9,
      "items": {
        "$ref": "#/$defs/flow_step"
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_effect",
        "codex_may",
        "codex_must_not",
        "assistant_must_not",
        "human_authority_required"
      ],
      "properties": {
        "runtime_effect": {
          "type": "string",
          "const": "contract_only"
        },
        "codex_may": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "codex_must_not": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "assistant_must_not": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "human_authority_required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "owner_split": {
      "type": "array",
      "minItems": 13,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo",
          "owns",
          "must_not"
        ],
        "properties": {
          "repo": {
            "type": "string",
            "minLength": 1
          },
          "owns": {
            "type": "string",
            "minLength": 1
          },
          "must_not": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "flow_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "owner_repo",
        "authority_note"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "owner_repo": {
          "type": "string",
          "minLength": 1
        },
        "authority_note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
