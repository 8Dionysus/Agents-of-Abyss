{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/parts/governance-polis/schemas/experience_governance_audit_record_v1.json",
  "title": "Experience Governance Audit Record V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_result",
    "authority",
    "created_at",
    "decision_ref",
    "decision_refs",
    "evidence_refs",
    "findings",
    "id",
    "kind",
    "notes",
    "schema_version",
    "status"
  ],
  "properties": {
    "audit_result": {
      "type": "string",
      "minLength": 1
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor",
        "mode"
      ],
      "properties": {
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "reviewed"
          ]
        }
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "decision_ref": {
      "type": "string",
      "minLength": 1
    },
    "decision_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "experience.governance_audit"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "const": "v1"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "proposed"
      ]
    }
  }
}
