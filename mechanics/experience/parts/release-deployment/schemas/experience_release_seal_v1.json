{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/parts/release-deployment/schemas/experience_release_seal_v1.json",
  "title": "Experience Release Seal V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "created_at",
    "decision_hash",
    "evidence_refs",
    "id",
    "kind",
    "notes",
    "owner_repo",
    "seal_id",
    "sealed_by",
    "status",
    "version"
  ],
  "properties": {
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "decision_hash": {
      "type": "string",
      "minLength": 1,
      "pattern": "^sha256:.+"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "experience_release_seal_v1"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "Agents-of-Abyss"
    },
    "seal_id": {
      "type": "string",
      "minLength": 1
    },
    "sealed_by": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.0.0"
    }
  }
}
