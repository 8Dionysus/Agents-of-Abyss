{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-of-abyss.local/mechanics/experience/parts/office-operations/schemas/experience-v1-3-office-foundry-role-pairs.schema.json",
  "title": "experience_v1_3_office_foundry_role_pairs_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "planting_id",
    "campaign_wave",
    "status",
    "runtime_effect",
    "live_runtime_activation",
    "source_seed",
    "predecessor_surfaces",
    "existing_service_offices",
    "expanded_service_offices",
    "role_pairs",
    "kind_split_law",
    "foundry_flow",
    "hard_guards",
    "blocking_contracts",
    "authority",
    "owner_split"
  ],
  "properties": {
    "schema_version": {
      "const": "experience_v1_3_office_foundry_role_pairs_v1"
    },
    "planting_id": {
      "const": "experience_v1_3_office_foundry_role_pairs_center_contract"
    },
    "campaign_wave": {
      "const": "wave3_office_foundry_role_pairs"
    },
    "status": {
      "const": "center_office_foundry_role_pairs_contract_landed"
    },
    "runtime_effect": {
      "const": "none"
    },
    "live_runtime_activation": {
      "const": false
    },
    "source_seed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "archive_name",
        "seed_id",
        "version",
        "sha256",
        "claim_limit"
      ],
      "properties": {
        "archive_name": {
          "const": "aoa-experience-office-foundry-role-pairs-seed-v1_3.zip"
        },
        "seed_id": {
          "const": "aoa-experience-office-foundry-role-pairs-v1.3"
        },
        "version": {
          "const": "v1.3"
        },
        "sha256": {
          "const": "d7ccb771f742540fcee0becdbfc79de69c2f97b5704ac067029fec23fef90648"
        },
        "claim_limit": {
          "const": "archive_readable_not_owner_ready"
        }
      }
    },
    "predecessor_surfaces": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "string"
      }
    },
    "existing_service_offices": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "string"
      }
    },
    "expanded_service_offices": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string"
      }
    },
    "role_pairs": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/role_pair"
      }
    },
    "kind_split_law": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "string"
      }
    },
    "foundry_flow": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/flow_step"
      }
    },
    "hard_guards": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "string"
      }
    },
    "blocking_contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_identity",
        "activation_state",
        "recharter",
        "scar_rank_retention",
        "tos_boundary",
        "routing_boundary",
        "eval_boundary",
        "archive_consistency"
      ],
      "properties": {
        "actor_identity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "same_actor_id_cross_kind_allowed",
            "kind_required_on_pair_seeds",
            "assistant_id_must_differ_from_agonic_id"
          ],
          "properties": {
            "same_actor_id_cross_kind_allowed": {
              "const": false
            },
            "kind_required_on_pair_seeds": {
              "const": true
            },
            "assistant_id_must_differ_from_agonic_id": {
              "const": true
            }
          }
        },
        "activation_state": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed_landing_states",
            "active_allowed_during_landing"
          ],
          "properties": {
            "allowed_landing_states": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "active_allowed_during_landing": {
              "const": false
            }
          }
        },
        "recharter": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed_requesters",
            "blocked_requesters",
            "review_required"
          ],
          "properties": {
            "allowed_requesters": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "blocked_requesters": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "review_required": {
              "const": true
            }
          }
        },
        "scar_rank_retention": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "candidate_only_required",
            "durable_write_allowed",
            "scheduler_action_allowed"
          ],
          "properties": {
            "candidate_only_required": {
              "const": true
            },
            "durable_write_allowed": {
              "const": false
            },
            "scheduler_action_allowed": {
              "const": false
            }
          }
        },
        "tos_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "runtime_write_allowed",
            "direct_node_path_allowed",
            "canon_write_allowed"
          ],
          "properties": {
            "runtime_write_allowed": {
              "const": false
            },
            "direct_node_path_allowed": {
              "const": false
            },
            "canon_write_allowed": {
              "const": false
            }
          }
        },
        "routing_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "advisory_only",
            "meaning_definition_allowed",
            "live_agonic_activation_allowed"
          ],
          "properties": {
            "advisory_only": {
              "const": true
            },
            "meaning_definition_allowed": {
              "const": false
            },
            "live_agonic_activation_allowed": {
              "const": false
            }
          }
        },
        "eval_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bounded_verdict_only",
            "may_grant_scar_rank_closure"
          ],
          "properties": {
            "bounded_verdict_only": {
              "const": true
            },
            "may_grant_scar_rank_closure": {
              "const": false
            }
          }
        },
        "archive_consistency": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "fixture_generated_result_disagreement_allowed",
            "missing_handoff_contract_must_block"
          ],
          "properties": {
            "fixture_generated_result_disagreement_allowed": {
              "const": false
            },
            "missing_handoff_contract_must_block": {
              "const": true
            }
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_effect",
        "codex_may",
        "codex_must_not",
        "assistant_must_not",
        "derived_layers_must_not",
        "human_gates_required"
      ],
      "properties": {
        "contract_effect": {
          "const": "center_office_foundry_role_pairs_law_only"
        },
        "codex_may": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "codex_must_not": {
          "type": "array",
          "minItems": 10,
          "items": {
            "type": "string"
          }
        },
        "assistant_must_not": {
          "type": "array",
          "minItems": 8,
          "items": {
            "type": "string"
          }
        },
        "derived_layers_must_not": {
          "type": "array",
          "minItems": 8,
          "items": {
            "type": "string"
          }
        },
        "human_gates_required": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "owner_split": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "$ref": "#/$defs/owner_entry"
      }
    }
  },
  "$defs": {
    "owner_repo": {
      "enum": [
        "8Dionysus",
        "Agents-of-Abyss",
        "Dionysus",
        "Tree-of-Sophia",
        "abyss-stack",
        "aoa-agents",
        "aoa-evals",
        "aoa-kag",
        "aoa-memo",
        "aoa-playbooks",
        "aoa-routing",
        "aoa-sdk",
        "aoa-skills",
        "aoa-stats",
        "aoa-techniques"
      ]
    },
    "role_pair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "office",
        "assistant",
        "agonic",
        "hybrid_allowed",
        "handoff_contract_required",
        "scar_authority"
      ],
      "properties": {
        "office": {
          "type": "string"
        },
        "assistant": {
          "type": "string"
        },
        "agonic": {
          "type": "string"
        },
        "hybrid_allowed": {
          "const": false
        },
        "handoff_contract_required": {
          "const": true
        },
        "scar_authority": {
          "const": "none_from_center"
        }
      }
    },
    "flow_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order",
        "kind",
        "owner",
        "authority_note",
        "stop_lines"
      ],
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "kind": {
          "type": "string"
        },
        "owner": {
          "$ref": "#/$defs/owner_repo"
        },
        "authority_note": {
          "type": "string"
        },
        "stop_lines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "owner_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "owns",
        "must_not"
      ],
      "properties": {
        "repo": {
          "$ref": "#/$defs/owner_repo"
        },
        "owns": {
          "type": "string"
        },
        "must_not": {
          "type": "string"
        }
      }
    }
  }
}
