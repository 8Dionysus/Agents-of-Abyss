{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/parts/office-operations/schemas/office_mesh_dashboard_v1.json",
  "title": "Office Mesh Dashboard V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "active_offices",
    "created_at",
    "evidence_refs",
    "id",
    "kind",
    "metrics",
    "notes",
    "owner_repo",
    "status",
    "version"
  ],
  "properties": {
    "active_offices": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "office_mesh_dashboard_v1"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_health",
        "incident_count",
        "scope_fidelity"
      ],
      "properties": {
        "handoff_health": {
          "type": "number",
          "minimum": 0
        },
        "incident_count": {
          "type": "integer",
          "minimum": 0
        },
        "scope_fidelity": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "Agents-of-Abyss"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.1.0"
    }
  }
}
