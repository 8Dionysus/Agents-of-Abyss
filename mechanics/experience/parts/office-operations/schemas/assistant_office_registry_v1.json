{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/parts/office-operations/schemas/assistant_office_registry_v1.json",
  "title": "Assistant Office Registry V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "baseline_office",
    "created_at",
    "evidence_refs",
    "expansion_offices",
    "id",
    "kind",
    "notes",
    "offices",
    "owner_repo",
    "status",
    "version"
  ],
  "properties": {
    "baseline_office": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "expansion_offices": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "assistant_office_registry_v1"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "offices": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "default_version",
              "evolution_mode",
              "kind",
              "mandate",
              "office",
              "office_id",
              "self_modification_allowed",
              "status"
            ],
            "properties": {
              "default_version": {
                "type": "string",
                "minLength": 1
              },
              "evolution_mode": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "minLength": 1,
                "const": "assistant"
              },
              "mandate": {
                "type": "string",
                "minLength": 1
              },
              "office": {
                "type": "string",
                "minLength": 1
              },
              "office_id": {
                "type": "string",
                "minLength": 1
              },
              "self_modification_allowed": {
                "type": "boolean",
                "const": false
              },
              "status": {
                "type": "string",
                "minLength": 1,
                "enum": [
                  "active",
                  "allowed",
                  "applied",
                  "blocked",
                  "completed",
                  "draft",
                  "failed",
                  "held",
                  "passed",
                  "proposed",
                  "rejected",
                  "rolled_back",
                  "sealed",
                  "train_candidate"
                ]
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "default_version",
              "evolution_mode",
              "kind",
              "mandate",
              "office",
              "office_id",
              "self_modification_allowed",
              "status"
            ],
            "properties": {
              "default_version": {
                "type": "string",
                "minLength": 1
              },
              "evolution_mode": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "minLength": 1,
                "const": "assistant"
              },
              "mandate": {
                "type": "string",
                "minLength": 1
              },
              "office": {
                "type": "string",
                "minLength": 1
              },
              "office_id": {
                "type": "string",
                "minLength": 1
              },
              "self_modification_allowed": {
                "type": "boolean",
                "const": false
              },
              "status": {
                "type": "string",
                "minLength": 1,
                "enum": [
                  "active",
                  "allowed",
                  "applied",
                  "blocked",
                  "completed",
                  "draft",
                  "failed",
                  "held",
                  "passed",
                  "planned",
                  "proposed",
                  "rejected",
                  "rolled_back",
                  "sealed"
                ]
              }
            }
          }
        ]
      },
      "minItems": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "Agents-of-Abyss"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.1.0"
    }
  }
}
