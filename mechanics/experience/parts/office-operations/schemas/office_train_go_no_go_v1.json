{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/parts/office-operations/schemas/office_train_go_no_go_v1.json",
  "title": "Office Train Go No Go V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "checks",
    "created_at",
    "decision",
    "evidence_refs",
    "id",
    "kind",
    "notes",
    "owner_repo",
    "status",
    "version"
  ],
  "properties": {
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "compatibility_matrix",
        "handoff_graph",
        "registry",
        "replay",
        "rollback_plan",
        "smoke_gates"
      ],
      "properties": {
        "authority": {
          "type": "boolean"
        },
        "compatibility_matrix": {
          "type": "boolean"
        },
        "handoff_graph": {
          "type": "boolean"
        },
        "registry": {
          "type": "boolean"
        },
        "replay": {
          "type": "boolean"
        },
        "rollback_plan": {
          "type": "boolean"
        },
        "smoke_gates": {
          "type": "boolean"
        }
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "office_train_go_no_go_v1"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "Agents-of-Abyss"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.1.0"
    }
  }
}
