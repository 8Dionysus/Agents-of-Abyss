{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Agents-of-Abyss/mechanics/experience/parts/office-operations/schemas/assistant_office_profile_v1.json",
  "title": "Assistant Office Profile V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "created_at",
    "evidence_refs",
    "id",
    "kind",
    "mandate",
    "notes",
    "office_id",
    "owner_repo",
    "service_contract",
    "status",
    "version"
  ],
  "properties": {
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "assistant_office_profile_v1"
    },
    "mandate": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "office_id": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "aoa-agents"
    },
    "service_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prohibited",
        "scope"
      ],
      "properties": {
        "prohibited": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.1.0"
    }
  }
}
