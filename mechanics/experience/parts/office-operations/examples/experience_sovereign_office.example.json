{
  "schema_version": "experience_sovereign_office_v1",
  "contract_ref": "experience_sovereign_office",
  "status": "sovereign_release_live_office_expansion_contract_gated",
  "source_receipt_refs": [
    "experience.seed.sovereign-release",
    "experience.seed.live-office-expansion"
  ],
  "installation_flow": [
    {
      "kind": "seed_prepared",
      "owner_repo": "Agents-of-Abyss",
      "authority_note": "center declares installable order without executing release"
    },
    {
      "kind": "landing_order_declared",
      "owner_repo": "Agents-of-Abyss",
      "authority_note": "owner-local landing order stays explicit"
    },
    {
      "kind": "migration_backed_up",
      "owner_repo": "abyss-stack",
      "authority_note": "runtime migration must cite a backup before activation"
    },
    {
      "kind": "smoke_gates_passed",
      "owner_repo": "aoa-evals",
      "authority_note": "proof gate records bounded verdicts before release"
    },
    {
      "kind": "operator_review_completed",
      "owner_repo": "Agents-of-Abyss",
      "authority_note": "operator review is required before seal"
    },
    {
      "kind": "sovereign_release_sealed",
      "owner_repo": "Agents-of-Abyss",
      "authority_note": "Codex cannot self-seal a durable release"
    },
    {
      "kind": "rollback_drill_passed",
      "owner_repo": "abyss-stack",
      "authority_note": "rollback path must be rehearsed before closeout"
    },
    {
      "kind": "post_release_watch_scheduled",
      "owner_repo": "aoa-agents",
      "authority_note": "assistant watch observes without self-promotion"
    }
  ],
  "office_train_flow": [
    {
      "kind": "notary_office_anchor_confirmed",
      "owner_repo": "aoa-agents",
      "authority_note": "notary.assistant remains first receipt-bearing anchor"
    },
    {
      "kind": "office_registry_declared",
      "owner_repo": "Agents-of-Abyss",
      "authority_note": "registry declares offices without hidden self-enroll"
    },
    {
      "kind": "bootstrap_order_notary_first",
      "owner_repo": "aoa-playbooks",
      "authority_note": "train bootstrap preserves notary-first ordering"
    },
    {
      "kind": "handoff_graph_receipts_required",
      "owner_repo": "aoa-routing",
      "authority_note": "handoffs require receipts and forbid hidden meaning edits"
    },
    {
      "kind": "compatibility_matrix_passed",
      "owner_repo": "aoa-evals",
      "authority_note": "compatibility is proven before train activation"
    },
    {
      "kind": "train_smoke_gates_passed",
      "owner_repo": "aoa-evals",
      "authority_note": "train smoke gates block failed releases"
    },
    {
      "kind": "rollback_plan_declared",
      "owner_repo": "abyss-stack",
      "authority_note": "rollback plan and quarantine path are mandatory"
    },
    {
      "kind": "operator_go_no_go_recorded",
      "owner_repo": "Agents-of-Abyss",
      "authority_note": "operator decision remains outside Codex self-approval"
    },
    {
      "kind": "train_seal_recorded",
      "owner_repo": "Agents-of-Abyss",
      "authority_note": "train seal requires reviewed authority"
    },
    {
      "kind": "replay_and_watch_scheduled",
      "owner_repo": "aoa-memo",
      "authority_note": "memory stores bounded lineage and watch markers only"
    }
  ],
  "authority": {
    "runtime_effect": "contract_only",
    "codex_may": [
      "prepare patchsets",
      "simulate migrations",
      "run smoke checks",
      "produce reports",
      "open owner-local PRs"
    ],
    "codex_must_not": [
      "certify releases",
      "seal releases",
      "approve release trains",
      "self-release",
      "suppress material evidence",
      "write directly to Tree-of-Sophia",
      "force owner adoption",
      "author routing meaning"
    ],
    "assistant_must_not": [
      "self-release",
      "self-enroll",
      "self-certify",
      "self-recharter",
      "hide durable behavior adoption",
      "launder service revisions into agonic scars"
    ],
    "human_authority_required": [
      "operator release seal",
      "operator train approval",
      "Tree-of-Sophia intake review",
      "owner-local activation",
      "rollback or hold override"
    ]
  },
  "office_contract": {
    "first_office": "notary.assistant",
    "required_primary_offices": [
      "notary.assistant",
      "concierge.assistant",
      "courier.assistant",
      "monitor.assistant"
    ],
    "non_primary_until_promoted": [
      "librarian.assistant",
      "steward.assistant",
      "scheduler.assistant"
    ],
    "office_kind": "assistant",
    "evolution_mode": "exogenous_reactive",
    "self_modification_allowed": false,
    "direct_tos_runtime_write_allowed": false
  },
  "owner_split": [
    {
      "repo": "Agents-of-Abyss",
      "owns": "center law, release authority, office train stop-lines",
      "must_not": "absorb owner-local execution"
    },
    {
      "repo": "Tree-of-Sophia",
      "owns": "dossier intake boundary and no-runtime-write guard",
      "must_not": "receive direct runtime writes"
    },
    {
      "repo": "abyss-stack",
      "owns": "runtime workers, storage plans, rollback mechanics",
      "must_not": "own doctrine or meaning"
    },
    {
      "repo": "aoa-agents",
      "owns": "assistant office profiles, service contracts, post-release watch",
      "must_not": "grant assistants self-authority"
    },
    {
      "repo": "aoa-evals",
      "owns": "smoke, replay, handoff, and certification verdicts",
      "must_not": "execute release authority"
    },
    {
      "repo": "aoa-kag",
      "owns": "derived precedent and pattern candidates",
      "must_not": "force adoption"
    },
    {
      "repo": "aoa-memo",
      "owns": "bounded memory entries, retention markers, revision ledgers",
      "must_not": "become proof"
    },
    {
      "repo": "aoa-playbooks",
      "owns": "runbooks and drills",
      "must_not": "turn choreography into authority"
    },
    {
      "repo": "aoa-routing",
      "owns": "route gates, handoff packets, service-to-agon boundaries",
      "must_not": "author routing meaning"
    },
    {
      "repo": "aoa-sdk",
      "owns": "typed API calls and controlled orchestration",
      "must_not": "absorb source-owned meaning"
    },
    {
      "repo": "aoa-skills",
      "owns": "bounded skill invocation contracts",
      "must_not": "become an activation authority"
    },
    {
      "repo": "aoa-stats",
      "owns": "derived dashboards and rollups",
      "must_not": "judge meaning"
    },
    {
      "repo": "aoa-techniques",
      "owns": "reusable technique notes",
      "must_not": "certify release results"
    }
  ]
}
