{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/8Dionysus/Agents-of-Abyss/mechanics/experience/parts/capture-kernel/schemas/experience-capture-flow.schema.json",
  "title": "experience_capture_flow_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_ref",
    "status",
    "source_receipt_refs",
    "candidate",
    "events",
    "verdict",
    "memory_gate",
    "owner_route",
    "projection",
    "authority"
  ],
  "properties": {
    "schema_version": {
      "const": "experience_capture_flow_v1"
    },
    "contract_ref": {
      "const": "experience_capture_flow"
    },
    "status": {
      "const": "center_kernel_seeded"
    },
    "source_receipt_refs": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "experience.seed.mechanic",
          "experience.seed.runtime-capture",
          "experience.seed.pilot-integration"
        ]
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_ref",
        "title",
        "friction_refs",
        "recurrence_ref",
        "intended_owner_repo",
        "status"
      ],
      "properties": {
        "candidate_ref": {
          "type": "string",
          "pattern": "^experience\\.candidate\\.[a-z0-9_.-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 3
        },
        "friction_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "recurrence_ref": {
          "type": "string",
          "minLength": 3
        },
        "intended_owner_repo": {
          "$ref": "#/$defs/repo"
        },
        "status": {
          "enum": [
            "declared",
            "accepted_for_owner_landing",
            "needs_revision",
            "rejected",
            "deferred"
          ]
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "kind",
          "candidate_ref",
          "summary",
          "actor_role",
          "evidence_refs"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "pattern": "^experience\\.event\\.[a-z0-9_.-]+$"
          },
          "kind": {
            "enum": [
              "friction_observed",
              "recurrence_detected",
              "candidate_declared",
              "review_verdict_recorded",
              "memory_gate_decided",
              "owner_route_selected",
              "projection_proposed"
            ]
          },
          "candidate_ref": {
            "type": "string"
          },
          "summary": {
            "type": "string",
            "minLength": 10
          },
          "actor_role": {
            "type": "string",
            "minLength": 3
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_ref",
        "decision",
        "reviewer_role",
        "rationale",
        "evidence_refs"
      ],
      "properties": {
        "candidate_ref": {
          "type": "string"
        },
        "decision": {
          "enum": [
            "accepted_for_owner_landing",
            "needs_revision",
            "rejected",
            "deferred"
          ]
        },
        "reviewer_role": {
          "type": "string"
        },
        "rationale": {
          "type": "string",
          "minLength": 10
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "memory_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_ref",
        "decision",
        "owner_repo",
        "rationale",
        "write_performed"
      ],
      "properties": {
        "candidate_ref": {
          "type": "string"
        },
        "decision": {
          "enum": [
            "no_memory",
            "memo_candidate",
            "memo_writeback_requested"
          ]
        },
        "owner_repo": {
          "enum": [
            "none",
            "aoa-memo"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 10
        },
        "write_performed": {
          "const": false
        }
      }
    },
    "owner_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_ref",
        "primary_repo",
        "downstream_repos",
        "non_authority_repos",
        "routing_status"
      ],
      "properties": {
        "candidate_ref": {
          "type": "string"
        },
        "primary_repo": {
          "$ref": "#/$defs/repo"
        },
        "downstream_repos": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo"
          }
        },
        "non_authority_repos": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo"
          }
        },
        "routing_status": {
          "const": "owner_review_required"
        }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_ref",
        "status",
        "allowed_surfaces",
        "must_not"
      ],
      "properties": {
        "candidate_ref": {
          "type": "string"
        },
        "status": {
          "enum": [
            "not_requested",
            "proposed_dry_run",
            "owner_local_only",
            "blocked"
          ]
        },
        "allowed_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "must_not": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "center_owns",
        "not_owned_here",
        "runtime_effect"
      ],
      "properties": {
        "center_owns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "not_owned_here": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "runtime_effect": {
          "const": "none"
        }
      }
    }
  },
  "$defs": {
    "repo": {
      "type": "string",
      "enum": [
        "Agents-of-Abyss",
        "Dionysus",
        "aoa-stats",
        "aoa-playbooks",
        "aoa-evals",
        "aoa-memo",
        "aoa-routing",
        "aoa-agents",
        "aoa-sdk",
        "abyss-stack"
      ]
    }
  }
}
