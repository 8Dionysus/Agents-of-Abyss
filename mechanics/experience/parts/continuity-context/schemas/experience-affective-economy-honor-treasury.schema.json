            "no honor debt without ttl",
            "no direct rights revocation"
          ]
        },
        {
          "order": 6,
          "kind": "assistant_service_affect_boundary_checked",
          "owner": "aoa-agents",
          "authority_note": "assistant affect stays service-regulatory and session-bounded, never agonic pride or persistent self-rewrite",
          "stop_lines": [
            "no assistant agonic pride",
            "no persistent affect self-rewrite"
          ]
        },
        {
          "order": 7,
          "kind": "affective_routing_hint_requested",
          "owner": "aoa-routing",
          "authority_note": "routing may surface bounded hints and escalation pressure but cannot route as verdict or authority",
          "stop_lines": [
            "no route as verdict",
            "no automatic escalation"
          ]
        },
        {
          "order": 8,
          "kind": "repair_and_retention_candidate_requested",
          "owner": "aoa-memo",
          "authority_note": "memo may receive repair and retention candidates but cannot write durable memory or execute retention here",
          "stop_lines": [
            "no durable memory write",
            "no retention execution"
          ]
        },
        {
          "order": 9,
          "kind": "summon_and_rights_gate_checked",
          "owner": "aoa-evals",
          "authority_note": "affect-to-rights pressure stays eval-gated and human reviewed; no affective packet may grant summon or rights directly",
