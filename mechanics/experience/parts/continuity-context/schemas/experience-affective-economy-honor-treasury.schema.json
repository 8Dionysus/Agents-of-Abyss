            "no affect-to-rights direct grant",
            "no summon by affect alone"
          ]
        },
        {
          "order": 10,
          "kind": "derived_observability_candidate_requested",
          "owner": "aoa-stats",
          "authority_note": "derived dashboards may summarize bounded affective packets but cannot become sovereign scores or verdicts",
          "stop_lines": [
            "no stats as authority",
            "no dashboard as verdict"
          ]
        },
        {
          "order": 11,
          "kind": "downstream_canon_and_kag_boundary_checked",
          "owner": "Agents-of-Abyss",
