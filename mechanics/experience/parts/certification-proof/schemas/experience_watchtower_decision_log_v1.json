{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "experience_watchtower_decision_log",
  "type": "object",
  "description": "experience_watchtower_decision_log schema for AoA experience deployment watchtower v0.5.",
  "required": [
    "decision_id",
    "decision_type",
    "actor",
    "authorized",
    "inputs",
    "outcome"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "decision_type": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "authorized": {
      "type": "boolean"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outcome": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
