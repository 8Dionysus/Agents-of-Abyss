{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "experience_watch_policy",
  "type": "object",
  "description": "experience_watch_policy schema for AoA experience deployment watchtower v0.5.",
  "required": [
    "policy_id",
    "watch_window_cycles",
    "alarm_thresholds",
    "promotion_requirements",
    "rollback_requirements"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "watch_window_cycles": {
      "type": "integer"
    },
    "alarm_thresholds": {
      "type": "object"
    },
    "promotion_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
