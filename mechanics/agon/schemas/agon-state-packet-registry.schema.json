{
  "$id": "https://8dionysus.dev/mechanics/agon/schemas/agon-state-packet-registry.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "live_protocol": {
      "const": false
    },
    "packet_count": {
      "minimum": 1,
      "type": "integer"
    },
    "packet_types": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "packets": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "registry_id": {
      "const": "agon.state_packet_models.wave9"
    },
    "runtime_effect": {
      "const": "none"
    },
    "status": {
      "const": "seeded_pre_protocol_packet_model"
    },
    "version": {
      "type": "string"
    },
    "wave": {
      "const": "IX"
    }
  },
  "required": [
    "registry_id",
    "version",
    "status",
    "wave",
    "live_protocol",
    "runtime_effect",
    "packet_count",
    "packet_types",
    "packets"
  ],
  "title": "Agon State Packet Registry",
  "type": "object"
}
