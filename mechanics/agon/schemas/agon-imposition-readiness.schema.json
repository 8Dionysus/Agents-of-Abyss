{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://8dionysus.github.io/Agents-of-Abyss/schemas/agon-imposition-readiness.schema.json",
  "title": "Agon Imposition Readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "owner_repo",
    "surface_kind",
    "status",
    "imposition_statement",
    "authority_refs",
    "baseline_refs",
    "survival_axes",
    "verdicts",
    "owner_handoffs",
    "stop_lines",
    "validation_refs",
    "next_allowed_waves"
  ],
  "properties": {
    "schema_version": {"const": "agon_imposition_readiness_v1"},
    "owner_repo": {"const": "Agents-of-Abyss"},
    "surface_kind": {"const": "agon_imposition_gate"},
    "status": {"enum": ["seed", "landed", "superseded"]},
    "imposition_statement": {"type": "string", "minLength": 1},
    "authority_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "baseline_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "survival_axes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["axis", "question", "owner_guard"],
        "properties": {
          "axis": {"type": "string", "minLength": 1},
          "question": {"type": "string", "minLength": 1},
          "owner_guard": {"type": "string", "minLength": 1}
        }
      }
    },
    "verdicts": {
      "type": "array",
      "minItems": 5,
      "items": {"enum": ["survive", "recharter", "defer", "prune", "quarantine"]},
      "uniqueItems": true
    },
    "owner_handoffs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["concern", "owner", "boundary", "next_wave"],
        "properties": {
          "concern": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "boundary": {"type": "string", "minLength": 1},
          "next_wave": {"type": "string", "minLength": 1}
        }
      }
    },
    "stop_lines": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "validation_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "next_allowed_waves": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
