{
  "$id": "https://github.com/8Dionysus/Agents-of-Abyss/mechanics/agon/schemas/agon-move-owner-binding.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "assistant_boundary": {
      "minLength": 20,
      "type": "string"
    },
    "binding_intent": {
      "minLength": 20,
      "type": "string"
    },
    "binding_status": {
      "const": "seeded_pre_protocol_owner_binding"
    },
    "live_protocol": {
      "const": false
    },
    "move_class": {
      "enum": [
        "stance",
        "evidence",
        "trace",
        "contradiction",
        "closure",
        "summon",
        "witness",
        "revision",
        "boundary",
        "escalation"
      ],
      "type": "string"
    },
    "move_id": {
      "pattern": "^agon\\.move\\.[a-z_]+\\.[a-z0-9_]+$",
      "type": "string"
    },
    "name": {
      "minLength": 3,
      "type": "string"
    },
    "owner_bindings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "candidate_refs": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "does_not_own": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "owner_repo": {
            "enum": [
              "Agents-of-Abyss",
              "aoa-techniques",
              "aoa-skills",
              "aoa-evals",
              "aoa-routing",
              "aoa-playbooks",
              "aoa-memo",
              "aoa-stats",
              "aoa-agents"
            ],
            "type": "string"
          },
          "owner_role": {
            "type": "string"
          },
          "owns_later": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "status": {
            "enum": [
              "center_law_binding_seeded",
              "requested_not_landed"
            ],
            "type": "string"
          }
        },
        "required": [
          "owner_repo",
          "owner_role",
          "candidate_refs",
          "status",
          "owns_later",
          "does_not_own"
        ],
        "type": "object"
      },
      "minItems": 2,
      "type": "array",
      "uniqueItems": false
    },
    "readiness": {
      "const": "owner_binding_seeded"
    },
    "runtime_effect": {
      "const": "none"
    },
    "stop_lines": {
      "items": {
        "type": "string"
      },
      "minItems": 5,
      "type": "array"
    },
    "wave": {
      "const": "IV"
    }
  },
  "required": [
    "move_id",
    "name",
    "move_class",
    "binding_status",
    "wave",
    "live_protocol",
    "runtime_effect",
    "binding_intent",
    "owner_bindings",
    "assistant_boundary",
    "stop_lines",
    "readiness"
  ],
  "title": "Agon move owner binding",
  "type": "object"
}
