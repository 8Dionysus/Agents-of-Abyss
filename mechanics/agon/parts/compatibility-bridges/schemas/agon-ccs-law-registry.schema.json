{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "home_repo": {
      "const": "Agents-of-Abyss"
    },
    "interlock_count": {
      "type": "integer"
    },
    "interlock_ids": {
      "minItems": 1,
      "type": "array"
    },
    "law_families": {
      "minItems": 3,
      "type": "array"
    },
    "live_protocol": {
      "const": false
    },
    "registry_id": {
      "const": "agon.ccs_law.registry.v1"
    },
    "runtime_effect": {
      "const": "none"
    },
    "stop_lines": {
      "minItems": 1,
      "type": "array"
    },
    "lineage_ref": {
      "const": "ccs-bridge"
    }
  },
  "required": [
    "registry_id",
    "version",
    "lineage_ref",
    "home_repo",
    "status",
    "live_protocol",
    "runtime_effect",
    "law_families",
    "interlock_ids",
    "interlock_count",
    "stop_lines"
  ],
  "title": "Agon CCS Law Registry",
  "type": "object"
}
