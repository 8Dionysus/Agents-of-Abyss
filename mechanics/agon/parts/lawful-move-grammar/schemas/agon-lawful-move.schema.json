{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/8Dionysus/Agents-of-Abyss/mechanics/agon/parts/lawful-move-grammar/schemas/agon-lawful-move.schema.json",
  "title": "Agon lawful move",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "move_id",
    "name",
    "move_class",
    "intent",
    "allowed_actor_forms",
    "allowed_seats",
    "preconditions",
    "must_not",
    "produces",
    "future_owner_handoffs",
    "status",
    "wave",
    "live_protocol",
    "runtime_effect",
    "center_owns",
    "not_owned_here"
  ],
  "properties": {
    "move_id": {
      "type": "string",
      "pattern": "^agon\\.move\\.[a-z_]+\\.[a-z0-9_]+$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "move_class": {
      "type": "string",
      "enum": [
        "stance",
        "evidence",
        "trace",
        "contradiction",
        "closure",
        "summon",
        "witness",
        "revision",
        "boundary",
        "escalation"
      ]
    },
    "intent": {
      "type": "string",
      "minLength": 10
    },
    "allowed_actor_forms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "agonic_contestant_candidate",
          "agonic_witness_candidate",
          "agonic_judge_candidate",
          "assistant_service_actor"
        ]
      }
    },
    "allowed_seats": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "contestant",
          "witness",
          "judge_candidate",
          "service_actor"
        ]
      }
    },
    "preconditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "must_not": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "produces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "future_owner_handoffs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string"
        }
      }
    },
    "status": {
      "const": "seeded_pre_protocol"
    },
    "wave": {
      "const": "III"
    },
    "live_protocol": {
      "const": false
    },
    "runtime_effect": {
      "const": "none"
    },
    "center_owns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "not_owned_here": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
