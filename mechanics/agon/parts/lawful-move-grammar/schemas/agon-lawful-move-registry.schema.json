{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/8Dionysus/Agents-of-Abyss/mechanics/agon/parts/lawful-move-grammar/schemas/agon-lawful-move-registry.schema.json",
  "title": "Agon lawful move registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_by",
    "source",
    "lineage_ref",
    "status",
    "counts",
    "non_goals",
    "moves"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_by": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "lineage_ref": {
      "const": "lawful-move-grammar"
    },
    "status": {
      "const": "pre_protocol_lawful_move_language"
    },
    "counts": {
      "type": "object",
      "required": [
        "total",
        "by_class",
        "by_actor_form",
        "by_seat"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 1
        },
        "by_class": {
          "type": "object"
        },
        "by_actor_form": {
          "type": "object"
        },
        "by_seat": {
          "type": "object"
        }
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "moves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "agon-lawful-move.schema.json"
      }
    }
  }
}
