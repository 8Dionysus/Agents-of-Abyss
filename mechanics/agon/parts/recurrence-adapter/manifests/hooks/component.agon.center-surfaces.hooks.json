      "signal_rules": [
        {
          "attributes_from_fields": [
            "schema_version",
            "status"
          ],
          "category": "change_pressure",
          "match": "always",
          "signal": "agon_recurrence_surface_changed",
          "source_inputs": [
            "agon-center-generated-surfaces"
          ]
        }
      ]
    },
