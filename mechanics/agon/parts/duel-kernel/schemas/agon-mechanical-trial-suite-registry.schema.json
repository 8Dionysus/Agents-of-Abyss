{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "count": {
      "minimum": 0,
      "type": "integer"
    },
    "digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "registry_id": {
      "const": "agon.mechanical_trial_suite.registry.v0"
    },
    "runtime_posture": {
      "type": "string"
    },
    "trials": {
      "items": {
        "$ref": "./agon-mechanical-trial-suite.schema.json"
      },
      "type": "array"
    },
    "wave": {
      "const": "XIII"
    }
  },
  "required": [
    "registry_id",
    "wave",
    "runtime_posture",
    "count",
    "trials",
    "digest"
  ],
  "type": "object"
}
