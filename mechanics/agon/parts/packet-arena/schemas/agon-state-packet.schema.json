{
  "$id": "https://8dionysus.dev/mechanics/agon/parts/packet-arena/schemas/agon-state-packet.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "actor": {
      "additionalProperties": true,
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "agonic",
            "assistant",
            "system"
          ]
        },
        "office": {
          "type": "string"
        },
        "seat_role": {
          "type": "string"
        }
      },
      "required": [
        "actor_id",
        "kind"
      ],
      "type": "object"
    },
    "constraints": {
      "additionalProperties": true,
      "properties": {
        "forbidden_effects": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "stop_lines": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "stop_lines"
      ],
      "type": "object"
    },
    "lifecycle_slot": {
      "type": "string"
    },
    "live_protocol": {
      "const": false
    },
    "packet_id": {
      "type": "string"
    },
    "packet_type": {
      "pattern": "^agon\\.",
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "protocol": {
      "const": "agon/state-packet/0.1"
    },
    "runtime_effect": {
      "const": "none"
    },
    "sequence": {
      "additionalProperties": true,
      "properties": {
        "logical_step": {
          "minimum": 0,
          "type": "integer"
        },
        "prev_packet_hash": {
          "type": "string"
        },
        "prev_packet_ref": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "session_draft_ref": {
      "type": "string"
    },
    "session_model_id": {
      "type": "string"
    },
    "wave": {
      "const": "IX"
    }
  },
  "required": [
    "protocol",
    "packet_type",
    "packet_id",
    "wave",
    "live_protocol",
    "runtime_effect",
    "actor",
    "payload",
    "constraints"
  ],
  "title": "Agon State Packet",
  "type": "object"
}
