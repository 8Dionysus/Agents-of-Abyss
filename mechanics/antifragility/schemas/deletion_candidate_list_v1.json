{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/seed/schemas/deletion_candidate_list_v1.json",
  "title": "deletion_candidate_list_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_utc",
    "scope",
    "guardrails",
    "candidates"
  ],
  "properties": {
    "schema_version": {
      "const": "deletion_candidate_list_v1"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace",
        "pass_kind",
        "candidate_mode"
      ],
      "properties": {
        "workspace": {
          "type": "string",
          "minLength": 1
        },
        "pass_kind": {
          "const": "via_negativa_pruning"
        },
        "candidate_mode": {
          "enum": [
            "inspect_first",
            "owner_scoped",
            "evidence_aware"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "repo",
          "path_glob",
          "candidate_kind",
          "fragility_family",
          "why_fragile",
          "detection_hints",
          "preferred_action",
          "owner_review_required",
          "status",
          "priority"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "minLength": 1
          },
          "path_glob": {
            "type": "string",
            "minLength": 1
          },
          "candidate_kind": {
            "enum": [
              "doc_or_readme",
              "schema_or_example",
              "generated_view",
              "route_hint",
              "memory_object_kind",
              "eval_bundle",
              "technique_or_skill",
              "profile_or_playbook",
              "runtime_or_helper",
              "projection_pack",
              "workspace_surface"
            ]
          },
          "fragility_family": {
            "type": "string",
            "minLength": 1
          },
          "why_fragile": {
            "type": "string",
            "minLength": 1
          },
          "detection_hints": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "preferred_action": {
            "enum": [
              "merge",
              "move",
              "deprecate",
              "delete",
              "suppress",
              "quarantine"
            ]
          },
          "preferred_keep_surface": {
            "type": [
              "string",
              "null"
            ]
          },
          "owner_review_required": {
            "type": "boolean"
          },
          "never_delete_without": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "status": {
            "enum": [
              "inspect_first",
              "safe_to_merge_if_duplicate",
              "safe_to_move_if_misplaced",
              "owner_review_required"
            ]
          },
          "priority": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
