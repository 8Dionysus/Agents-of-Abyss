{
  "schema": "aoa.link_shape_hygiene.v1",
  "wave": "E",
  "purpose": "Guard local links, Markdown shape, status vocabularies, generated freshness, and known link-drift repairs without becoming a source-of-truth layer.",
  "protocol_ref": "docs/LINK_AND_SHAPE_HYGIENE_PROTOCOL.md",
  "index_ref": "docs/HYGIENE_GUARDRAIL_INDEX.md",
  "generated_ref": "generated/link_shape_hygiene.min.json",
  "link_validation": {
    "scan_globs": [
      "**/*.md"
    ],
    "exclude_globs": [
      ".git/**",
      ".github/**/*.md.bak",
      ".mypy_cache/**",
      ".pytest_cache/**",
      ".ruff_cache/**",
      ".venv/**",
      "venv/**",
      "node_modules/**",
      "__pycache__/**",
      ".wave_*_backups/**",
      "docs/traces/conflicts/**"
    ],
    "ignore_schemes": [
      "http",
      "https",
      "mailto",
      "tel",
      "data"
    ],
    "check_anchors_by_default": false,
    "known_rewrites": [
      {
        "id": "federation-rules-recurrence-principle-route",
        "file": "docs/FEDERATION_RULES.md",
        "old": "(RECURRENCE_PRINCIPLE.md)",
        "new": "(../mechanics/recurrence/docs/RECURRENCE_PRINCIPLE.md)",
        "reason": "Recurrence principle is mechanic-local, not a flat docs neighbor."
      },
      {
        "id": "landings-agon-log-mechanic-route",
        "file": "docs/landings/README.md",
        "old": "](../AGON_LANDING_LOG.md)",
        "new": "](../../mechanics/agon/LANDING_LOG.md)",
        "reason": "Agon landing log moved from flat docs into the mechanics/agon package."
      },
      {
        "id": "landings-experience-log-mechanic-route",
        "file": "docs/landings/README.md",
        "old": "](../EXPERIENCE_LANDING_LOG.md)",
        "new": "](../../mechanics/experience/LANDING_LOG.md)",
        "reason": "Experience landing log moved from flat docs into the mechanics/experience package."
      },
      {
        "id": "antifragility-via-negativa-local-route",
        "file": "mechanics/antifragility/FRAGILITY_BLACKLIST.md",
        "old": "[docs/VIA_NEGATIVA](mechanics/antifragility/docs/VIA_NEGATIVA.md)",
        "new": "[VIA_NEGATIVA](docs/VIA_NEGATIVA.md)",
        "reason": "Mechanic-local doctrine should route relative to the antifragility package root."
      },
      {
        "id": "antifragility-deletion-candidates-audit-route",
        "file": "mechanics/antifragility/FRAGILITY_BLACKLIST.md",
        "old": "[docs/audits/DELETION_CANDIDATES.json](docs/audits/DELETION_CANDIDATES.json)",
        "new": "[docs/audits/DELETION_CANDIDATES.json](../../docs/audits/DELETION_CANDIDATES.json)",
        "reason": "Deletion candidates are root docs audit evidence, not antifragility-local files."
      },
      {
        "id": "antifragility-root-surface-law-route",
        "file": "mechanics/antifragility/FRAGILITY_BLACKLIST.md",
        "old": "[docs/ROOT_SURFACE_LAW](docs/ROOT_SURFACE_LAW.md)",
        "new": "[docs/ROOT_SURFACE_LAW](../../docs/ROOT_SURFACE_LAW.md)",
        "reason": "Root surface law remains under root docs governance."
      },
      {
        "id": "method-growth-rootline-recurrence-route",
        "file": "mechanics/method-growth/docs/ROOTLINE.md",
        "old": "[RECURRENCE_PRINCIPLE](RECURRENCE_PRINCIPLE.md)",
        "new": "[RECURRENCE_PRINCIPLE](../../recurrence/docs/RECURRENCE_PRINCIPLE.md)",
        "reason": "Rootline recurrence reference crosses from method-growth docs to recurrence doctrine."
      },
      {
        "id": "release-support-releasing-changelog-route",
        "file": "mechanics/release-support/docs/RELEASING.md",
        "old": "[CHANGELOG](../CHANGELOG.md)",
        "new": "[CHANGELOG](../../../CHANGELOG.md)",
        "reason": "Repo changelog stays at repository root, three levels above release-support docs."
      }
    ]
  },
  "markdown_shape": {
    "default_max_line_length": 700,
    "default_min_lines": 1,
