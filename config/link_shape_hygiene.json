  "status_vocabulary": {
    "mechanic_status": [
      "planted",
      "landed",
      "requested",
      "operational",
      "deprecated"
    ],
    "owner_request_status": [
      "queued",
      "requested",
      "accepted",
      "landed",
      "blocked",
      "superseded",
      "retired"
    ],
    "maturity_status": [
      "seed",
      "proven",
      "promoted",
      "canonical",
      "deprecated"
    ],
    "hygiene_status": [
      "planned",
      "active",
      "warning",
      "blocked",
      "retired"
    ]
  },
  "status_checks": [
    {
      "file": "mechanics/registry.json",
      "json_path": "mechanics.*.status",
      "vocabulary": "mechanic_status",
      "required": false
    },
    {
      "file": "generated/mechanic_card_index.min.json",
      "json_path": "mechanics.*.status",
      "vocabulary": "mechanic_status",
      "required": false
    },
    {
      "file": "mechanics/owner-request-queue.json",
      "json_path": "requests.*.queue_status",
      "vocabulary": "owner_request_status",
      "required": false
    },
    {
      "file": "generated/owner_request_queue.min.json",
      "json_path": "requests.*.queue_status",
      "vocabulary": "owner_request_status",
      "required": false
    },
    {
      "file": "generated/link_shape_hygiene.min.json",
      "json_path": "guardrails.*.status",
      "vocabulary": "hygiene_status",
      "required": true
    }
  ],
  "generated_freshness": [
    {
      "output": "generated/center_entry_map.min.json",
      "builder": "scripts/build_center_entry_map.py",
      "check_args": [
        "--check"
